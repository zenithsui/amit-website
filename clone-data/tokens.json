  "button": {
    "fontSize": "15px",
    "fontWeight": "700",
    "fontFamily": "sans-serif",
    "lineHeight": "22.5px",
    "letterSpacing": "normal",
    "color": "rgb(36, 31, 33)",
    "textTransform": "none",
    "textAlign": "center",
    "backgroundColor": "rgba(0, 0, 0, 0)",
    "padding": "0px 11.25px 0px 0px",
    "borderRadius": "0px",
    "border": "1px solid rgba(0, 0, 0, 0)"
  },
  "cssVars": [
    [
      "--initial-100vh",
      "100vh"
    ],
    [
      "--native-scrollbar-width",
      "0px"
    ],
    [
      "--computed-100vh",
      "100vh"
    ],
    [
      "--computed-100vw",
      "calc(100vw - var(--native-scrollbar-width))"
    ],
    [
      "--grid-columns",
      "24"
    ],
    [
      "--grid-gap",
      "clamp(14px,9.71px + 100vw * .011,28px)"
    ],
    [
      "--grid-half-gap",
      "calc(var(--grid-gap)*.5)"
    ],
    [
      "--grid-margin",
      "clamp(16px,10.15px + 100vw * .015,36px)"
    ],
    [
      "--grid-padding",
      "calc(var(--grid-margin) - var(--grid-gap)*.5)"
    ],
    [
      "--grid-width",
      "calc(var(--100vw) - var(--grid-margin)*2)"
    ],
    [
      "--modal-row-width",
      "calc((var(--100vw) - 2*var(--grid-padding))/1.333 - var(--grid-gap) + var(--grid-gap) + var(--grid-padding))"
    ],
    [
      "--modal-width",
      "calc(var(--modal-row-width) + var(--grid-half-gap))"
    ],
    [
      "--100vw",
      "100vw"
    ],
    [
      "--lvh",
      "1lvh"
    ],
    [
      "--dvh",
      "1dvh"
    ],
    [
      "--svh",
      "1svh"
    ]
  ],
  "fonts": [],
  "selfHostedFonts": [
    {
      "family": "Zimula",
      "src": "url(\"/_nuxt/Zimula-Variable.Cb2n2uX-.ttf\") format(\"truetype\")",
      "weight": "400",
      "style": "normal"
    }
  ],
  "title": "Floema\u00ae \u2014 Spaces for people, made for life.",
  "metaDescription": "Signage, furniture, and equipment for building functional and sustainable spaces that are open to communities and promote a fulfilling way of life."
